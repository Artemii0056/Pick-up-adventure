    FailNextNodeId: fail_end
    Choices: []
  - Id: success_end
    Text: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u044D\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
