    IsEnd: 1
    Action: 0
    SuccessNextNodeId: 
    FailNextNodeId: 
    Choices:
    - Text: "\u041B\u0430\u0434\u043D\u043E, \u043F\u043E\u0438\u0449\u0443 \u0435\u0449\u0451"
