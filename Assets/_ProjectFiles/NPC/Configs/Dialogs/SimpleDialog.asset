--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ac109d292c6e405a88a35c08a12be073, type: 3}
  m_Name: SimpleDialog
  m_EditorClassIdentifier: Assembly-CSharp::_ProjectFiles.Dialogue.Data.DialogueConfig
  DialogueId: npc_intro_1
  StartNodeId: start
  Nodes:
  - Id: start
    Text: "\u041F\u0440\u0438\u0432\u0435\u0442, \u043F\u0443\u0442\u043D\u0438\u043A.
      \u0427\u0442\u043E \u0442\u044B \u0437\u0434\u0435\u0441\u044C \u0438\u0449\u0435\u0448\u044C?"
    IsEnd: 0
    Action: 0
    Choices:
    - Text: "\u0414\u0430"
      NextNodeId: look
    - Text: "\u041D\u0435\u0442"
      NextNodeId: treasure
  - Id: look
    Text: "\u041E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C\u0441\u044F
      \u043F\u043E\u043B\u0435\u0437\u043D\u043E. \u0418\u043D\u043E\u0433\u0434\u0430
      \u043E\u0442\u0432\u0435\u0442\u044B \u043B\u0435\u0436\u0430\u0442 \u043F\u0440\u044F\u043C\u043E
      \u043F\u0435\u0440\u0435\u0434 \u0433\u043B\u0430\u0437\u0430\u043C\u0438."
    IsEnd: 0
    Action: 0
    Choices:
    - Text: " \u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u0441\u043E\u0432\u0435\u0442"
      NextNodeId: good_end
  - Id: treasure
    Text: "\u0421\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0430 \u0438\u0449\u0443\u0442
      \u043C\u043D\u043E\u0433\u0438\u0435. \u041D\u043E \u043D\u0435 \u0432\u0441\u0435
      \u0433\u043E\u0442\u043E\u0432\u044B \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u0442\u044C
      \u0446\u0435\u043D\u0443."
    IsEnd: 0
    Action: 0
    Choices:
    - Text: "\u042F \u0432\u0441\u0451 \u0440\u0430\u0432\u043D\u043E \u043D\u0430\u0439\u0434\u0443
        \u0438\u0445"
      NextNodeId: bad_end
  - Id: good_end
    Text: "\u0425\u043E\u0440\u043E\u0448\u0438\u0439 \u043E\u0442\u0432\u0435\u0442.
      \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0443 \u0442\u0435\u0431\u044F
      \u0435\u0449\u0451 \u0435\u0441\u0442\u044C \u0448\u0430\u043D\u0441."
    IsEnd: 1
    Action: 0
    Choices: []
  - Id: bad_end
    Text: "\u0422\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D.
      \u0416\u0430\u0434\u043D\u043E\u0441\u0442\u044C \u0440\u0435\u0434\u043A\u043E
      \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u043A \u0434\u043E\u0431\u0440\u0443."
    IsEnd: 1
    Action: 0
    Choices: []
